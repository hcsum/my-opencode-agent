{
  "name": "opencode-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram and Gmail bridges with switchable Codex/OpenCode backends",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:gmail": "CHANNELS=gmail tsx src/index.ts",
    "dev:telegram": "CHANNELS=telegram tsx src/index.ts",
    "dev:opencode": "AGENT_BACKEND=opencode tsx src/index.ts",
    "start:opencode:stack": "bash scripts/start-opencode-stack.sh",
    "gmail:reauth": "tsx scripts/gmail-reauth.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:gmail": "CHANNELS=gmail node dist/index.js",
    "start:opencode": "AGENT_BACKEND=opencode node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@openai/codex": "^0.123.0",
    "@openai/codex-sdk": "^0.123.0",
    "@opencode-ai/sdk": "^1.14.24",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "googleapis": "^171.4.0",
    "telegraf": "^4.16.3",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
