{
  "name": "opencode-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenCode workspace with skills, notes, and Gmail bridge",
  "scripts": {
    "bridge": "bash scripts/bridge.sh",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "notes:backup": "bash scripts/backup-notes.sh",
    "notes:bootstrap": "bash scripts/bootstrap-notes.sh",
    "notes:ensure": "bash scripts/ensure-notes.sh",
    "notes:sync": "bash scripts/sync-notes.sh",
    "start": "node dist/index.js",
    "opencode": "bash scripts/opencode-local.sh",
    "serve": "bash scripts/start-opencode-serve.sh",
    "serve-and-bridge": "bash scripts/serve-and-bridge.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate-ingest": "tsx src/validate-ingest.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.20",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "googleapis": "^171.4.0",
    "playwright-core": "^1.54.1",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
