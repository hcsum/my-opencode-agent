# Comma-separated channels to run: telegram,gmail (default), gmail, telegram
CHANNELS=telegram,gmail

# Telegram bridge (optional)
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Codex SDK / CLI auth and runtime.
# Use CODEX_API_KEY or OPENAI_API_KEY. If both are set, CODEX_API_KEY wins.
CODEX_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Optional explicit codex binary path.
CODEX_PATH=
# Bridge-safe default is never (non-interactive); other options: on-request, on-failure, untrusted
CODEX_APPROVAL_POLICY=never
# read-only | workspace-write | danger-full-access
CODEX_SANDBOX_MODE=workspace-write
# Optional: minimal | low | medium | high | xhigh
CODEX_REASONING_EFFORT=
# Optional: true/false
CODEX_NETWORK_ACCESS=
# Optional comma-separated paths added to Codex thread sandbox when using workspace-write.
# Default if empty: $HOME,$HOME/.web-access,$HOME/.gmail-mcp
CODEX_ADDITIONAL_DIRS=

# Used by the local seo MCP server when needed.
CAPSOLVER_API_KEY=

# Optional bridge state file.
STATE_FILE=.data/state.json

# Optional Google Drive notes backup target folder.
GDRIVE_NOTES_BACKUP_FOLDER_ID=

# Optional Gmail bridge. Set GMAIL_LABEL to enable.
# Gmail OAuth credentials must be in ~/.gmail-mcp/ (gcp-oauth.keys.json + credentials.json).
GMAIL_TO=sumtsui+agent@gmail.com
GMAIL_POLL_INTERVAL_MS=60000
# Used by bridge and gmail:reauth for Google API calls.
GMAIL_PROXY=http://127.0.0.1:7890
