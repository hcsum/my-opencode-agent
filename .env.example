OPENCODE_BASE_URL=http://127.0.0.1:4096
# Optional: fallback model used automatically when the primary hits a 429 rate limit.
# Format: provider/modelid  e.g. anthropic/claude-sonnet-4-5
# OPENCODE_MODEL_FALLBACK=
# Custom OpenCode provider injected in code (src/opencode-server-config.ts) and
# fed to the server at spawn time via OPENCODE_CONFIG_CONTENT. Leave empty to
# skip registering the PackyApi provider. Use models as packyapi-usage/gpt-5.4.
PACKYAPI_API_KEY=
# Optional if your OpenCode server uses basic auth.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
# Optional OpenCode serve runtime (used by npm run serve:opencode).
OPENCODE_SERVE_PORT=4096
# Optional shared proxy for OpenCode serve + Gmail bridge.
HTTPS_PROXY=http://127.0.0.1:7890

# Optional Debian apt mirror used during the Docker image build (wired into
# docker-compose build.args). Leave unset to use the upstream CDN; set a domestic
# mirror to speed up builds behind a slow cross-border link.
# APT_MIRROR=mirrors.tuna.tsinghua.edu.cn

# Optional npm registry used during the Docker image build. Leave unset to use
# the default npm registry; set a mirror to speed up `npm install` / `npm ci`.
# NPM_REGISTRY=https://registry.npmmirror.com/

# Used by the local seo MCP server when needed.
CAPSOLVER_API_KEY=

# Optional cloud browser providers for web-access.
# If Browserbase is set, web-access uses Browserbase.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_CONTEXT_ID=
BROWSERBASE_CONTEXT_PERSIST=true
BROWSERBASE_USE_PROXY=
BROWSERBASE_SOLVE_CAPTCHA=
BROWSERBASE_VERIFIED=
BROWSERBASE_REGION=ap-southeast-1
BROWSERBASE_SESSION_TIMEOUT_SEC=

STATE_FILE=.data/state.json

# Private notes repo bootstrap + sync.
# Local example: https://github.com/hcsum/my-agent-notes.git
# VPS example with SSH config host alias: git@github.com-my-agent-notes:hcsum/my-agent-notes.git
NOTES_REPO_URL=
# Recommended: a GitHub fine-grained PAT scoped to the notes repo with
# Contents read+write. When set, ensure-notes.sh switches the notes remote to
# HTTPS and authenticates with this token in every environment (container,
# host, CI) — no ssh key, host alias, or per-user ssh config needed, and it
# lets the agent push notes from inside the container. The token is read from
# the environment by a git credential helper and never written to .git/config.
# Leave empty to keep using the SSH form of NOTES_REPO_URL above.
NOTES_REPO_TOKEN=

# Commit identity for the notes repo. Needed on hosts without a global git
# identity (e.g. the VPS Docker container) so the agent can commit notes.
# Set at the repo level only; never touches the host global git config.
# NOTES_GIT_USER_EMAIL falls back to USER_EMAIL below if unset.
NOTES_GIT_USER_NAME=opencode-agent
NOTES_GIT_USER_EMAIL=

# Credential/state dirs are mounted from the project's .secrets/ in
# docker-compose (host sources are hardcoded there, no override vars). The
# global ~/.config/opencode is intentionally NOT mounted: custom providers are
# injected in code and provider auth lives in the share dir's auth.json.

# Optional Gmail bridge.
# Gmail OAuth credentials must live in the GMAIL_MCP_DIR above
# (gcp-oauth.keys.json + credentials.json).
AGENT_INBOX_EMAIL=sumtsui+agent@gmail.com
USER_EMAIL=sumtsui@gmail.com
# Backward-compatible legacy names:
# GMAIL_TO=sumtsui+agent@gmail.com
# SCHEDULED_RESULTS_TO=sumtsui@gmail.com
GMAIL_POLL_INTERVAL_MS=60000
# Set to a short window (e.g. 1h) on fresh deploys to skip historical emails.
GMAIL_NEWER_THAN=3d

# --- Long-term memory (mem0 + Qdrant, .opencode/plugin/mem0-memory.ts) ---
# REQUIRED for memory: both embeddings and the extraction LLM run on Gemini
# (GOOGLE_API_KEY). opencode's own model auth is separate (oauth), so this must
# be set explicitly or memory disables itself on load.
# Get a Gemini key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Qdrant vector store. Local dev: localhost. In docker-compose the agent
# service overrides this to http://qdrant:6333 (compose service DNS).
QDRANT_URL=http://localhost:6333
# Namespace all of this user's memories under one id.
MEM0_USER_ID=sum
# Qdrant collection name (override only to run isolated stores).
# MEM0_COLLECTION=pikachu_memory
# Per-agent slug for the generated audit files (SNAPSHOT.<id>.md /
# CONFLICTS.<id>.md). The local and VPS agents share the notes/ git repo but
# keep separate Qdrant stores, so each must own its own snapshot file to avoid
# merge conflicts on sync. Defaults to the hostname; set explicitly for a clean
# name (e.g. MEM0_AGENT_ID=vps on the server, MEM0_AGENT_ID=local on your mac).
# MEM0_AGENT_ID=local
# Gemini embedding model + its output dimension (set explicitly so mem0 doesn't
# make an extra probe call). gemini-embedding-001 supports 768/1536/3072; we pin
# 1536 to keep the Qdrant collection dimension unchanged from the OpenAI setup.
MEM0_EMBED_MODEL=gemini-embedding-001
# MEM0_EMBED_DIMS=1536
# Cheap extraction LLM mem0 runs on every add — NOT the session model.
# MEM0_LLM_MODEL=gemini-2.5-flash-lite
# mem0 phones home to PostHog (telemetry + notice flags) inside add/search and
# can stall writes if that egress is blocked. The plugin defaults this off; set
# to "true" only if you actually want mem0 telemetry.
# MEM0_TELEMETRY=false

# Background auto-extraction from conversations on idle. Set to 0 to disable
# (keyword "记住/remember" capture still works regardless).
MEMORY_EXTRACT_ENABLED=1
# Idle debounce before a conversation is mined, in ms. Fires once the user pauses.
MEMORY_EXTRACT_DEBOUNCE_MS=60000

# Audit snapshot (notes/memory/SNAPSHOT.<agent>.md) regenerated from the store
# on churn or interval; the notes repo sync diffs it. mem0/Qdrant is the store
# of record. Filename is namespaced per agent (see MEM0_AGENT_ID above).
# MEMORY_SNAPSHOT_CHURN=5
# MEMORY_SNAPSHOT_INTERVAL_MS=43200000
