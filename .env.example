OPENCODE_BASE_URL=http://127.0.0.1:4096
# Optional if your OpenCode server uses basic auth.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
# Optional OpenCode serve runtime (used by npm run serve:opencode).
OPENCODE_SERVE_PORT=4096
# Optional shared proxy for OpenCode serve + Gmail bridge.
HTTPS_PROXY=http://127.0.0.1:7890

# Used by the local seo MCP server when needed.
CAPSOLVER_API_KEY=

# Optional cloud browser providers for web-access.
# If Browserbase is set, web-access uses Browserbase.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_CONTEXT_ID=
BROWSERBASE_CONTEXT_PERSIST=true
BROWSERBASE_USE_PROXY=
BROWSERBASE_SOLVE_CAPTCHA=
BROWSERBASE_VERIFIED=
BROWSERBASE_REGION=ap-southeast-1
BROWSERBASE_SESSION_TIMEOUT_SEC=

STATE_FILE=.data/state.json

# Private notes repo bootstrap + sync.
# Local example: https://github.com/hcsum/my-agent-notes.git
# VPS example with SSH config host alias: git@github.com-my-agent-notes:hcsum/my-agent-notes.git
NOTES_REPO_URL=
# Recommended: a GitHub fine-grained PAT scoped to the notes repo with
# Contents read+write. When set, ensure-notes.sh switches the notes remote to
# HTTPS and authenticates with this token in every environment (container,
# host, CI) — no ssh key, host alias, or per-user ssh config needed, and it
# lets the agent push notes from inside the container. The token is read from
# the environment by a git credential helper and never written to .git/config.
# Leave empty to keep using the SSH form of NOTES_REPO_URL above.
NOTES_REPO_TOKEN=

# Commit identity for the notes repo. Needed on hosts without a global git
# identity (e.g. the VPS Docker container) so the agent can commit notes.
# Set at the repo level only; never touches the host global git config.
# NOTES_GIT_USER_EMAIL falls back to USER_EMAIL below if unset.
NOTES_GIT_USER_NAME=opencode-agent
NOTES_GIT_USER_EMAIL=

# Host-side credential/state dirs mounted into the container (docker-compose).
# Defaults are project-relative (./.secrets/...) so they resolve identically no
# matter which user runs `docker compose`. Only set these to an absolute path
# when adopting an existing/legacy box whose creds already live elsewhere.
# GMAIL_MCP_DIR=./.secrets/gmail-mcp
# OPENCODE_SHARE_DIR=./.secrets/opencode-share
# OPENCODE_CONFIG_DIR=./.secrets/opencode-config

# Optional Gmail bridge.
# Gmail OAuth credentials must live in the GMAIL_MCP_DIR above
# (gcp-oauth.keys.json + credentials.json).
AGENT_INBOX_EMAIL=sumtsui+agent@gmail.com
USER_EMAIL=sumtsui@gmail.com
# Backward-compatible legacy names:
# GMAIL_TO=sumtsui+agent@gmail.com
# SCHEDULED_RESULTS_TO=sumtsui@gmail.com
GMAIL_POLL_INTERVAL_MS=60000
# Set to a short window (e.g. 1h) on fresh deploys to skip historical emails.
GMAIL_NEWER_THAN=3d
